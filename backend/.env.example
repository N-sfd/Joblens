# --- Product scope ---
# Set to false once the CRM/ATS consolidation is stable and the standalone
# job-seeker product (auth, resume analyzer, job matcher, job tracker, cover
# letter generator, browser extension, etc.) is being sunset. Router code is
# kept, just not mounted — safe to flip back to true at any time.
SEEKER_PRODUCT_ENABLED=true

# --- AI provider ---
# The app calls Groq via the OpenAI-compatible SDK (services/claude_service.py).
# Set GROQ_API_KEY for resume/job parsing. ANTHROPIC_API_KEY is optional if you
# switch the client in claude_service.py to Anthropic directly.
GROQ_API_KEY=your_groq_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Database ---
# Local dev: SQLite (default). Production: managed PostgreSQL (Render/Supabase/Neon).
# A 'postgres://' URL is auto-normalized to 'postgresql://'.
DATABASE_URL=sqlite:///./aijob.db
# Example prod: postgresql://user:pass@host:5432/dbname
# Local Docker (see docker-compose.postgres.yml): host port 5433
# DATABASE_URL=postgresql://joblens:joblens@127.0.0.1:5433/joblens
# After setting Postgres URL, run migrations:
#   cd backend && python -m alembic upgrade head

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
# Production (Render): comma-separated origins, e.g.
# ALLOWED_ORIGINS=https://your-app.vercel.app

# --- Public job-seeker auth (existing) ---
SECRET_KEY=generate_a_long_random_secret_for_jwt_signing
ENV=development
# Set ENV=production on Render so the auth cookie uses SameSite=None; Secure.

# --- Private CRM/ATS: Clerk backend verification ---
# Used by ats_auth.py to verify Clerk session JWTs on private endpoints.
CLERK_SECRET_KEY=sk_test_...
CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://your-instance.clerk.accounts.dev
# Local dev: leave false (API works without a browser session).
# Production (Render): MUST be true — backend rejects unauthenticated ATS requests.
ATS_AUTH_ENFORCE=true
# Role-based access: admin | recruiter | manager | read_only
# (legacy "viewer" values are normalized to read_only automatically)
# Resolution order: JWT claims → Clerk API → local ats_staff_users → bootstrap → read_only
# Bootstrap first admin without Clerk metadata (comma-separated):
# ATS_BOOTSTRAP_ADMIN_EMAILS=anila@consultamerica.com
# ATS_BOOTSTRAP_ADMIN_USER_IDS=user_2abc...
# Or: python scripts/set_ats_db_role.py admin --clerk-user-id user_xxx --email you@company.com
# Optional: customize Clerk session token to include:
#   { "role": "{{user.public_metadata.role}}", "email": "{{user.primary_email_address}}" }
# - read_only: view only
# - manager: create/update (not delete / Zoho disconnect) — same write access as recruiter
# - recruiter: create/update (not delete / Zoho disconnect)
# - admin: full access including deletes, user management, integrations
ATS_BOOTSTRAP_ADMIN_EMAILS=
ATS_BOOTSTRAP_ADMIN_USER_IDS=

# --- Rate limits (per user/IP per minute) ---
AI_RATE_LIMIT_PER_MINUTE=20
ZOHO_RATE_LIMIT_PER_MINUTE=30
CSV_EXPORT_PER_MINUTE=10
REPORTS_PER_MINUTE=60
EXT_AUTH_CHALLENGE_PER_MINUTE=10
EXT_TOKEN_EXCHANGE_PER_MINUTE=8
EXT_TOKEN_REFRESH_PER_MINUTE=20
EXT_DIAGNOSTICS_PER_MINUTE=30
EXT_FILL_SESSION_PER_MINUTE=20
EXT_MAPPING_PER_MINUTE=40
EXT_UPLOAD_SESSION_PER_MINUTE=15
EXT_DOCUMENT_RETRIEVE_PER_MINUTE=10
EXT_SUBMISSION_CONFIRM_PER_MINUTE=10
EXT_FEEDBACK_PER_MINUTE=8

# --- Browser extension (Phase 5 M4) ---
# Production: set EXTENSION_JWT_SECRET separately; never fall back to a shared dev secret.
EXTENSION_JWT_SECRET=
EXTENSION_TOKEN_ISSUER=joblens-extension
EXTENSION_TOKEN_AUDIENCE=joblens-extension-api
EXTENSION_ALLOWED_ORIGINS=https://joblens.app,https://www.joblens.app
EXTENSION_ALLOWED_IDS=
EXTENSION_ALLOWED_VERSIONS=
EXTENSION_MIN_VERSION=0.4.0
EXTENSION_BLOCKED_VERSIONS=
EXTENSION_ACCESS_TOKEN_TTL_SECONDS=900
EXTENSION_REFRESH_TOKEN_TTL_SECONDS=604800
DOCUMENT_TOKEN_TTL_SECONDS=300
FRONTEND_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000
# Feature flags (pilot defaults documented in docs/PHASE5_M4_PILOT_CHECKLIST.md)
EXTENSION_ENABLED=true
EXTENSION_DIAGNOSTICS_ENABLED=true
EXTENSION_ASSISTED_FILL_ENABLED=true
EXTENSION_DOCUMENT_UPLOAD_ENABLED=true
EXTENSION_SUBMISSION_CONFIRMATION_ENABLED=true
EXTENSION_GREENHOUSE_ENABLED=true
EXTENSION_PILOT_USER_IDS=
# JobLens users.id values (integer), NOT Clerk user ids — see auth.Owner.user_id
EXTENSION_PILOT_GUEST_IDS=
EXTENSION_OPS_TOKEN=

# --- Resume/file storage ---
# local (dev default) | supabase | s3 | r2 | workdrive
STORAGE_PROVIDER=local
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_RESUME_BUCKET=resumes
# Seeker documents (extension uploads) — local private paths by default
SEEKER_DOCUMENT_MAX_BYTES=5242880

# --- Zoho Mail integration (Phase 4/5) ---
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REDIRECT_URI=http://localhost:3000/ats/settings/zoho/callback
ZOHO_ACCOUNTS_BASE_URL=https://accounts.zoho.com
ZOHO_MAIL_API_BASE_URL=https://mail.zoho.com
# Fernet key for encrypting Zoho refresh tokens at rest:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# =============================================================================
# Render production checklist (set in Render dashboard → Environment):
#   DATABASE_URL          = postgresql://...
#   GROQ_API_KEY          = gsk_...
#   CLERK_SECRET_KEY      = sk_live_...
#   CLERK_JWKS_URL        = https://<instance>.clerk.accounts.dev/.well-known/jwks.json
#   CLERK_ISSUER          = https://<instance>.clerk.accounts.dev
#   ATS_AUTH_ENFORCE      = true
#   ALLOWED_ORIGINS       = https://your-frontend.vercel.app
#   TOKEN_ENCRYPTION_KEY  = (Fernet key)
#   ENV                   = production
#   SECRET_KEY            = (long random string)
#   EXTENSION_JWT_SECRET  = (long random string, distinct)
#   EXTENSION_MIN_VERSION = 0.4.0
#   EXTENSION_PILOT_USER_IDS = (comma-separated)
# Set Clerk public_metadata.role = admin|recruiter|manager|read_only for each user.
# Then run once: alembic upgrade head  (or add to Render build/start command)
# =============================================================================

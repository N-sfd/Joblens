# --- AI provider ---
# NOTE: the app currently calls Groq via the OpenAI-compatible SDK
# (services/claude_service.py). Set GROQ_API_KEY. ANTHROPIC_API_KEY is kept for
# reference in case you switch providers.
GROQ_API_KEY=your_groq_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Database ---
# Local dev: SQLite (default). Production: managed PostgreSQL (Render/Supabase/Neon).
# A 'postgres://' URL is auto-normalized to 'postgresql://'.
DATABASE_URL=sqlite:///./aijob.db
# Example prod: postgresql://user:pass@host:5432/dbname

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000
# Production: comma-separated full origins OR hostnames (https:// added for non-localhost).
# Example: https://joblens-rosy.vercel.app or joblens-rosy.vercel.app

# --- Public job-seeker auth (existing) ---
SECRET_KEY=generate_a_long_random_secret_for_jwt_signing
ENV=development
# Set ENV=production on Render so the auth cookie uses SameSite=None; Secure.

# --- Private CRM/ATS: Clerk backend verification (Phase: auth hardening) ---
# Used by ats_auth.py to verify Clerk session JWTs on private endpoints.
CLERK_SECRET_KEY=sk_test_xxx
CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://your-instance.clerk.accounts.dev

# --- Resume/file storage (Phase 5) ---
# local (dev default) | supabase | s3 | r2 | workdrive
STORAGE_PROVIDER=local

# --- Zoho Mail integration (Phase 3/4) ---
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REDIRECT_URI=
ZOHO_ACCOUNTS_BASE_URL=https://accounts.zoho.com
ZOHO_MAIL_API_BASE_URL=https://mail.zoho.com
# Fernet key used to encrypt Zoho refresh tokens at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

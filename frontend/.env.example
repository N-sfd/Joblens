# Local: point at FastAPI (default if unset in browser on localhost).
NEXT_PUBLIC_API_URL=http://localhost:8000

# Vercel (optional alternative to NEXT_PUBLIC_API_URL):
# Set BACKEND_URL=https://your-api.onrender.com — no trailing slash.
# next.config rewrites proxy /api/* to the backend so the browser stays same-origin
# (avoids mixed content and you do not need NEXT_PUBLIC_API_URL for that setup).

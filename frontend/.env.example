# Set to false once the CRM/ATS consolidation is stable and the standalone
# job-seeker product (/, /dashboard, /jobs, /resume, /match, /cover-letter,
# /reminders, /applications, /profile, /extension) is being sunset. Routes are
# kept, just redirected to /ats — safe to flip back to true at any time.
NEXT_PUBLIC_SEEKER_PRODUCT_ENABLED=true

# Local: point at FastAPI (default if unset in browser on localhost).
NEXT_PUBLIC_API_URL=http://localhost:8000

# Vercel (optional alternative to NEXT_PUBLIC_API_URL):
# Set BACKEND_URL=https://your-api.onrender.com — no trailing slash.
# The server route app/api/[[...path]] proxies /api/* to that host (same-origin in the browser).

# Clerk (ATS/admin auth only — does not affect the public job-seeker tools below).
# Get keys from https://dashboard.clerk.com. Protects /employees, /job-requirements,
# /matches, /submissions, /settings — everything else (/, /resume, /match, /cover-letter,
# /jobs, /dashboard, /reminders) stays public.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

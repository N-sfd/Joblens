# Set to false for CRM-only production. When false, seeker routes redirect to /ats.
NEXT_PUBLIC_SEEKER_PRODUCT_ENABLED=false

# Local: FastAPI. Production: prefer BACKEND_URL only (same-origin /api proxy).
# Do NOT set NEXT_PUBLIC_API_URL on Vercel Preview/Production — it is baked into
# the browser bundle and causes CORS / Wrong-host "Failed to fetch" on staging.
# Optional local override only:
# NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=

# Vercel / server-side proxy target (Render CRM FastAPI root). Health must be:
# GET {BACKEND_URL}/health → {"status":"healthy"}
# If /health returns model_rmse / model_loaded, you have the wrong Render service.
BACKEND_URL=http://localhost:8000

# Optional production indicator (never put secrets in NEXT_PUBLIC_*).
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_PRODUCT_NAME=Consult America CRM

# Clerk — same production project as the backend. Protects /ats/* (and legacy redirects).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

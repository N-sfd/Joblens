# Set to false for CRM-only production. When false, seeker routes redirect to /ats.
NEXT_PUBLIC_SEEKER_PRODUCT_ENABLED=false

# Local: FastAPI. Production: https API root or use BACKEND_URL on Vercel for same-origin /api proxy.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional production indicator (never put secrets in NEXT_PUBLIC_*).
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_PRODUCT_NAME=Consult America CRM

# Clerk — same production project as the backend. Protects /ats/* (and legacy redirects).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
